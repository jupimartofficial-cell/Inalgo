# Copy to .env.production on your Oracle Cloud VM and set secure values.
DB_URL=jdbc:postgresql://postgres:5432/trade
DB_USERNAME=trade
DB_PASSWORD=change-me
DB_MAX_POOL_SIZE=24
DB_MIN_IDLE=4
POSTGRES_DB=trade
POSTGRES_USER=trade
POSTGRES_PASSWORD=change-me

ADMIN_SESSION_MINUTES=360
ADMIN_TRIGGER_POLL_MS=15000

# Restrict this to your production domain.
CORS_ALLOWED_ORIGINS=https://trade.example.com

# Broker/API configuration. Set secure tenant-scoped tokens through the Admin UI
# where possible; do not commit real tokens.
UPSTOX_BASE_URL=https://api.upstox.com
UPSTOX_ORDER_BASE_URL=https://api-hft.upstox.com
UPSTOX_MIGRATION_ENABLED=true
UPSTOX_OPTION_CHAIN_ENABLED=true
UPSTOX_OPTION_CHAIN_TENANT_ID=local-desktop
UPSTOX_OPTION_CHAIN_REFRESH_SECONDS=30
UPSTOX_OPTION_CHAIN_MAX_EXPIRIES=2

# India market-hours guardrails used by triggers and schedulers.
MARKET_HOURS_ZONE_ID=Asia/Kolkata
MARKET_HOURS_OPEN_TIME=09:15
MARKET_HOURS_CLOSE_TIME=16:00

# Market trend and optional AI analysis.
MARKET_SENTIMENT_ENABLED=true
MARKET_SENTIMENT_TENANT_ID=local-desktop
MARKET_SENTIMENT_CRON=0 */5 * * * *
MARKET_SENTIMENT_TIMEOUT_SECONDS=20
MARKET_SENTIMENT_NEWS_LOOKBACK_HOURS=48
MARKET_SENTIMENT_MAX_ITEMS_PER_SOURCE=8
OPENAI_MARKET_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MARKET_ANALYSIS_MODEL=gpt-4o-mini

# Trading Scripts worker.
TRADING_SCRIPTS_ENABLED=true
TRADING_SCRIPTS_WORKER_COMMAND=node
TRADING_SCRIPTS_WORKER_PATH=../scripts/trading-script-worker.mjs
TRADING_SCRIPTS_WORKER_TIMEOUT_MS=8000
TRADING_SCRIPTS_WORKER_MEMORY_MB=96
TRADING_SCRIPTS_MAX_SOURCE_LENGTH=50000

# Rate limiting.
API_RATE_LIMIT_PER_SECOND=50
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=5
ADMIN_LOGIN_RATE_LIMIT_PER_HOUR=25
