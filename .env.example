# Copy to .env for local Docker Compose usage.
# Replace all change-me values before running services.

POSTGRES_DB=trade
POSTGRES_USER=trade
POSTGRES_PASSWORD=change-me

DB_URL=jdbc:postgresql://postgres:5432/trade
DB_USERNAME=trade
DB_PASSWORD=change-me

ADMIN_SESSION_MINUTES=360

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENAI_MARKET_ENABLED=false
